# Prevent execution of scripts in uploads (defense-in-depth).
# Only static assets (images) should be served from this directory.
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<FilesMatch "\.(php[3-8]?|phtml|phar|php\.bak)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>
AddType application/octet-stream .php .php3 .php4 .php5 .php6 .php7 .php8 .phtml .phar
